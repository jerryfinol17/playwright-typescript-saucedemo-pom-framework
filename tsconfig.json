{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "@playwright/test"],
    "sourceMap": true,
    "inlineSourceMap": true,
    "inlineSources": true
  },
  "include": ["aprendiendoJS/**/*.ts", "playwright.config.ts"],
  "exclude": ["node_modules", "dist", "videos", "test-results", "playwright-report"]
}